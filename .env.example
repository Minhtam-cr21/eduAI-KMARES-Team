NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server only — đồng bộ lộ trình (bypass RLS). Không commit .env.local
# Giá trị: API key service_role (JWT eyJ…) hoặc sb_secret_… từ Settings → API — KHÔNG phải JWT Secret ở Settings → JWT
SUPABASE_SERVICE_ROLE_KEY=
# Tuỳ chọn: cùng giá trị như trên nếu bạn đặt tên biến theo JWT
# SUPABASE_SERVICE_ROLE_JWT_KEY=
# Tuỳ chọn (production): URL site cho OAuth redirect allow list
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Chỉ dùng trên server — không NEXT_PUBLIC, không commit .env.local
# AI debugger: /api/ai-suggest — thử OpenAI trước, lỗi/quota → DeepSeek, cuối cùng rule-based (không cần key)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-3.5-turbo
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# RapidAPI — Judge0 CE (server: /api/run-code; header x-rapidapi-key)
# Không dấu ngoặc, không khoảng trắng thừa; tên biến đúng trong .env: x-rapidapi-key (RapidAPI X-RapidAPI-Key).
# Sau khi sửa .env.local: dừng hẳn dev server (Ctrl+C) rồi chạy lại npm run dev — chỉ reload trang không nạp lại env.
# Kiểm tra: GET http://localhost:3000/api/test-key → 200 nếu key có, 503 nếu thiếu.
x-rapidapi-key=your_key_here
