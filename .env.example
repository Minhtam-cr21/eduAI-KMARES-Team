NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server only — đồng bộ lộ trình (bypass RLS). Không commit .env.local
# Giá trị: API key service_role (JWT eyJ…) hoặc sb_secret_… từ Settings → API — KHÔNG phải JWT Secret ở Settings → JWT
SUPABASE_SERVICE_ROLE_KEY=
# Tuỳ chọn: cùng giá trị như trên nếu bạn đặt tên biến theo JWT
# SUPABASE_SERVICE_ROLE_JWT_KEY=
# Bắt buộc trên Vercel: URL công khai (OAuth, email xác nhận, callback)
# NEXT_PUBLIC_APP_URL=https://edu-ai-kmares-team.vercel.app

# Chỉ dùng trên server — không NEXT_PUBLIC, không commit .env.local
# AI debugger (/api/ai-suggest): OpenAI if key set, else rule-based
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-3.5-turbo
# Provider order: openai,rule (default if unset)
# AI_PROVIDER_ORDER=openai,rule
# RapidAPI — Judge0 CE (server: /api/practice/run, /api/practice/quick-run)
# Tên biến môi trường: x_rapidapi_key (gạch dưới; tránh dấu gạch ngang trong một số môi trường deploy).
# Sau khi sửa .env.local: dừng hẳn dev server (Ctrl+C) rồi chạy lại npm run dev — chỉ reload trang không nạp lại env.
# Kiểm tra: GET http://localhost:3000/api/test-key → 200 nếu key có, 503 nếu thiếu.
x_rapidapi_key=your_key_here

# Resend — email thông báo deadline / đóng băng (server + Edge Function handle-missed-deadlines)
# RESEND_FROM_EMAIL="EduAI <noreply@yourdomain.com>"
RESEND_API_KEY=

# Deploy Edge Function + secrets trên Supabase Cloud (không commit file này):
# sao chép env.supabase.deploy.example → .env.supabase.deploy rồi chạy npm run supabase:deploy:deadlines
#
# GitHub Actions secret SUPABASE_ANON_KEY = cùng giá trị NEXT_PUBLIC_SUPABASE_ANON_KEY (JWT eyJ...), không phải token sbp_...
