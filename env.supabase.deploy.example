# Sao chép thành `.env.supabase.deploy` (đã gitignore) và điền giá trị thật.
# Dùng cho: npm run supabase:deploy:deadlines

# Bắt buộc — CHỈ Project ID / ref (chuỗi ngắn, ví dụ abcdefghijklmnopqrst).
# Lấy tại: Supabase Dashboard → Project Settings → General → Reference ID.
# KHÔNG dán: https://... , không dấu ngoặc, không xuống dòng thừa.
SUPABASE_PROJECT_REF=

# Bắt buộc — Dashboard → Account → Access Tokens (deploy function; GitHub Actions secret cùng tên nếu dùng "Deploy function trước")
SUPABASE_ACCESS_TOKEN=

# Bắt buộc — Dashboard → Settings → API → service_role (JWT eyJ... hoặc sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=

# Bắt buộc nếu muốn gửi mail từ Edge Function — resend.com → API Keys
RESEND_API_KEY=

# Tuỳ chọn — domain đã verify, ví dụ: EduAI <noreply@yourdomain.com>
RESEND_FROM_EMAIL=
